# Environment Configuration — Phase 1
# Copy this file to .env and adjust values for your deployment.

# Server
PORT=3000
NODE_ENV=production

# Phase 1 Simulation
TEST_OTP=123456

# Timeouts (milliseconds)
IDLE_TIMEOUT=60000
IDLE_WARNING=10000
SUCCESS_COUNTDOWN=30

# Verification delay (milliseconds) — simulates backend response time
VERIFY_DELAY=1500

# Max failed attempts per verification step
MAX_ATTEMPTS=3

# OTP expiry (seconds)
OTP_EXPIRY=300
MAX_OTP_RESENDS=3
