<!-- Animated Step Progress Bar (#4) -->
<% if (typeof step !== 'undefined') { %>
<div class="w-full max-w-3xl mx-auto mb-10">
  <div class="flex items-center justify-between mb-4">
    <% const steps = [
      { label: 'Student ID', i18n: 'step.studentId' },
      { label: 'Date of Birth', i18n: 'step.dob' },
      { label: 'Civil ID', i18n: 'step.civilId' },
      { label: 'Mobile', i18n: 'step.mobile' }
    ]; %>
    <% for (let i = 0; i < steps.length; i++) { %>
      <div class="flex flex-col items-center flex-1">
        <div class="progress-circle w-14 h-14 rounded-full flex items-center justify-center text-lg font-headline font-bold transition-all duration-500
          <%= i + 1 < step ? 'bg-primary text-on-primary' : i + 1 === step ? 'bg-gradient-to-br from-primary to-secondary text-on-primary shadow-[0_0_20px_rgba(2,230,0,0.4)]' : 'bg-surface-container-highest/50 text-on-surface-variant border border-outline-variant/30 opacity-60' %>"
          data-final-state="<%= i + 1 < step ? 'done' : i + 1 === step ? 'active' : 'pending' %>"
          style="transform: scale(0.5); opacity: 0;">
          <% if (i + 1 < step) { %>
            <span class="material-symbols-outlined text-xl check-pop">check</span>
          <% } else { %>
            <%= i + 1 %>
          <% } %>
        </div>
        <span class="text-sm mt-2 font-label tracking-wide uppercase transition-colors duration-300 text-center leading-tight
          <%= i + 1 <= step ? 'text-primary' : 'text-on-surface-variant/60' %>" data-i18n="<%= steps[i].i18n %>"><%= steps[i].label %></span>
      </div>
      <% if (i < steps.length - 1) { %>
        <div class="flex-1 h-1 mx-2 mt-[-22px] rounded-full bg-outline-variant/30 overflow-hidden">
          <div class="progress-bar h-full bg-gradient-to-r from-primary to-secondary rounded-full transition-all duration-700 ease-out" data-target-width="<%= i + 1 < step ? '100' : '0' %>" style="width: 0%;"></div>
        </div>
      <% } %>
    <% } %>
  </div>
</div>
<style>
  @keyframes checkPop {
    0% { transform: scale(0) rotate(-45deg); opacity: 0; }
    60% { transform: scale(1.3) rotate(5deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }
  .check-pop { animation: checkPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes activeStepPulse {
    0%, 100% { box-shadow: 0 0 20px rgba(2,230,0,0.4); }
    50% { box-shadow: 0 0 35px rgba(2,230,0,0.6), 0 0 60px rgba(94,212,255,0.2); }
  }
  .progress-circle[data-final-state="active"] {
    animation: activeStepPulse 2.5s ease-in-out infinite;
  }
</style>
<script>
  // Animate progress on load
  requestAnimationFrame(() => {
    setTimeout(() => {
      document.querySelectorAll('.progress-circle').forEach((el, i) => {
        setTimeout(() => {
          const state = el.dataset.finalState;
          el.style.transform = state === 'active' ? 'scale(1.15)' : 'scale(1)';
          el.style.opacity = state === 'pending' ? '0.6' : '1';
        }, i * 180);
      });
      document.querySelectorAll('.progress-bar').forEach((bar, i) => {
        setTimeout(() => {
          bar.style.width = bar.dataset.targetWidth + '%';
        }, i * 220 + 100);
      });
    }, 200);
  });
</script>
<% } %>
