<!-- Static Deep Background — simple fixed blobs, no animation -->
<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
  <!-- Cyan glow — top right -->
  <div class="bg-blob" style="width:580px;height:580px;top:-8%;right:-6%;background:radial-gradient(circle,rgba(94,212,255,0.22) 0%,transparent 70%);"></div>
  <!-- Green glow — bottom left -->
  <div class="bg-blob" style="width:620px;height:620px;bottom:-12%;left:-8%;background:radial-gradient(circle,rgba(2,230,0,0.18) 0%,transparent 70%);"></div>
  <!-- Pink accent — centre -->
  <div class="bg-blob" style="width:480px;height:480px;top:38%;left:28%;background:radial-gradient(circle,rgba(255,171,243,0.12) 0%,transparent 70%);"></div>
</div>

<style>
  .bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
  }
  /* High contrast mode: hide background blobs */
  html.high-contrast .bg-blob { display: none; }
</style>
