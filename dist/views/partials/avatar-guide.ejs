<!-- Animated Omani Avatar Guide — Top-right shy-peek mechanic -->
<div id="avatar-guide" class="fixed z-[90] pointer-events-none" style="right: 0; top: 60px; transform: translateX(100%);">
  <!-- Avatar character (clipped to show only head when peeking) -->
  <div id="avatar-character" class="pointer-events-auto cursor-pointer" style="width: 100px; height: 120px; overflow: hidden;" title="Tap me for help">
    <img src="/images/avatar-omani.svg?v=<%= Date.now() %>" alt="Omani Guide" class="w-full" id="avatar-svg-img" style="margin-top: -5px;" />
  </div>
  <!-- Speech bubble — positioned to the left of the avatar -->
  <div id="avatar-bubble" class="glass-panel absolute px-5 py-4 rounded-2xl rounded-tr-sm border border-primary/20 shadow-[0_0_30px_rgba(2,230,0,0.1)] pointer-events-auto opacity-0 transition-all duration-500" style="right: 110px; top: 10px; width: 280px; transform: scale(0.8) translateX(20px);">
    <!-- Bubble tail pointing right -->
    <div class="absolute -right-2 top-6 w-0 h-0" style="border-top: 8px solid transparent; border-bottom: 8px solid transparent; border-left: 10px solid rgba(19,43,69,0.6);"></div>
    <p id="avatar-message" class="text-on-surface text-base font-body leading-relaxed"></p>
    <!-- Dismiss button -->
    <button id="avatar-dismiss" class="absolute -top-2 -left-2 w-6 h-6 rounded-full bg-surface-container-highest/80 border border-outline-variant/30 flex items-center justify-center text-on-surface-variant hover:text-white hover:bg-error/60 transition-all" aria-label="Dismiss">
      <span class="material-symbols-outlined text-sm" style="font-size: 14px;">close</span>
    </button>
  </div>
</div>

<!-- RTL + Light mode overrides for avatar -->
<style>
  /* RTL: flip to left edge */
  [dir="rtl"] #avatar-guide {
    right: auto !important;
    left: 0;
    transform: translateX(-100%);
  }
  [dir="rtl"] #avatar-guide.avatar-peek, [dir="rtl"] #avatar-guide.avatar-expanded {
    /* handled by JS with negative direction */
  }
  [dir="rtl"] #avatar-bubble {
    right: auto !important;
    left: 110px;
    border-radius: 1rem 1rem 1rem 0.25rem;
  }
  [dir="rtl"] #avatar-bubble > div:first-child {
    right: auto;
    left: -8px;
    border-left: none;
    border-right: 10px solid rgba(19,43,69,0.6);
    border-left: 0;
  }
  [dir="rtl"] #avatar-character {
    transform: scaleX(-1);
  }
  /* Light mode bubble */
  html:not(.dark) #avatar-bubble {
    background: rgba(255,255,255,0.88);
    border-color: rgba(2,110,0,0.15);
    box-shadow: 0 0 20px rgba(0,0,0,0.06);
  }
  html:not(.dark) #avatar-bubble > div:first-child {
    border-left-color: rgba(255,255,255,0.88);
  }
  html:not(.dark) [dir="rtl"] #avatar-bubble > div:first-child {
    border-right-color: rgba(255,255,255,0.88);
    border-left-color: transparent;
  }
</style>
