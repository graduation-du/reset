<%- include('partials/head') %>

<%- include('partials/navbar') %>
<%- include('partials/background') %>
<%- include('partials/overlays') %>

<!-- Splash Screen — Tap Anywhere to Begin -->
<main id="splash-main" class="relative z-10 flex flex-col items-center justify-center min-h-screen px-10 pt-28 pb-40 cursor-pointer" data-prefetch="/verify/student-id">

    <!-- Hero Header -->
    <div class="text-center mb-14 max-w-3xl screen-transition">
      <h1 class="font-headline text-7xl font-black text-white leading-tight mb-6 tracking-tighter">
        <span data-i18n="splash.welcome">Welcome,</span> <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary" data-i18n="splash.student">Student.</span>
      </h1>
      <p class="font-headline text-3xl text-on-secondary-container font-light" data-i18n="splash.subtitle">
        Forgot your Email Password? Let's get you back online.
      </p>
    </div>

    <!-- Central Card -->
    <!-- Language Toggle Button (animated gradient border) -->
    <div id="splash-lang-toggle" class="lang-btn-glow mb-8 cursor-pointer screen-transition" style="animation-delay: 0.05s;">
      <div class="lang-btn-inner">
        <span class="material-symbols-outlined lang-icon">g_translate</span>
        <div class="flex flex-col">
          <span id="splash-lang-label-ar" class="font-arabic text-2xl font-bold text-white leading-tight">عربي</span>
          <span id="splash-lang-label-en" class="text-sm font-label text-on-surface-variant/70 tracking-wider uppercase">Switch to Arabic</span>
        </div>
        <span class="material-symbols-outlined text-on-surface-variant/40 text-xl ml-2">swap_horiz</span>
      </div>
    </div>

    <div class="relative w-full max-w-3xl screen-transition" style="animation-delay: 0.1s;">
      <div class="glass-panel p-12 rounded-[2.5rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] border-t border-white/10 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/20 blur-3xl rounded-full"></div>
        <div class="relative z-10 flex flex-col items-center text-center">

          <!-- Status Indicator -->
          <div class="mb-10 flex items-center gap-4 bg-surface-container-highest/50 px-8 py-3.5 rounded-full border border-outline-variant/20">
            <span class="relative flex h-4 w-4">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex rounded-full h-4 w-4 bg-primary"></span>
            </span>
            <span class="text-lg font-medium text-on-surface tracking-wide uppercase" data-i18n="splash.status">System Status: Ready</span>
          </div>

          <!-- Start Button Visual -->
          <div class="w-full flex flex-col items-center gap-8">
            <div class="btn-primary w-full py-8 px-10 rounded-2xl bg-gradient-to-br from-primary to-on-primary-fixed-variant flex items-center justify-center gap-6 overflow-hidden transition-all duration-300">
              <span class="material-symbols-outlined filled text-5xl text-on-primary">lock_reset</span>
              <span class="font-headline text-3xl font-black text-on-primary tracking-tight" data-i18n="splash.start">Start Password Reset</span>
            </div>
          </div>

          <!-- Tap Anywhere Hint -->
          <p class="mt-8 text-on-surface-variant/70 text-xl font-label tracking-wider uppercase animate-pulse" data-i18n="splash.tap">
            Tap anywhere to begin
          </p>

        </div>
      </div>

      <!-- Bottom Info Cards -->
      <div class="mt-8 grid grid-cols-2 gap-5">
        <div class="glass-panel p-6 rounded-2xl border border-white/5 flex items-center gap-4">
          <div class="p-3 bg-secondary/10 rounded-xl">
            <span class="material-symbols-outlined text-secondary text-2xl">location_on</span>
          </div>
          <div>
            <p class="text-sm font-label text-on-secondary-container uppercase tracking-widest" data-i18n="splash.location.label">Kiosk Location</p>
            <p class="font-headline font-bold text-white text-lg" data-i18n="splash.location.value">Main Admin Building</p>
          </div>
        </div>
        <div class="glass-panel p-6 rounded-2xl border border-white/5 flex items-center gap-4">
          <div class="p-3 bg-tertiary/10 rounded-xl">
            <span class="material-symbols-outlined text-tertiary text-2xl">schedule</span>
          </div>
          <div>
            <p class="text-sm font-label text-on-tertiary-container uppercase tracking-widest" data-i18n="splash.available.label">Available</p>
            <p class="font-headline font-bold text-white text-lg" data-i18n="splash.available.value">24/7 Self-Service</p>
          </div>
        </div>
      </div>
    </div>

</main>

<%- include('partials/footer') %>

<script>
(function () {
  var btn = document.getElementById('splash-lang-toggle');
  var labelAr = document.getElementById('splash-lang-label-ar');
  var labelEn = document.getElementById('splash-lang-label-en');
  if (!btn || typeof I18N === 'undefined') return;

  function updateLabel() {
    if (I18N.getLang() === 'ar') {
      labelAr.textContent = 'EN';
      labelEn.textContent = 'Switch to English';
    } else {
      labelAr.textContent = '\u0639\u0631\u0628\u064a';
      labelEn.textContent = 'Switch to Arabic';
    }
  }
  updateLabel();

  btn.addEventListener('pointerdown', function (e) {
    e.preventDefault();
    e.stopPropagation();
    I18N.toggleLang();
    updateLabel();
    // Also sync navbar toggle label
    var navLabel = document.querySelector('#lang-toggle span:last-child');
    if (navLabel) navLabel.textContent = I18N.getLang() === 'ar' ? 'EN' : '\u0639\u0631\u0628\u064a';
    // Update avatar guide message on language change
    if (typeof AvatarGuide !== 'undefined' && AvatarGuide.onLanguageChange) {
      AvatarGuide.onLanguageChange();
    }
  });

  // Tap anywhere (except the lang toggle) to start the wizard
  var splashMain = document.getElementById('splash-main');
  if (splashMain) {
    splashMain.addEventListener('click', function (e) {
      if (e.target.closest('#splash-lang-toggle')) return;
      if (typeof navigateTo !== 'undefined') navigateTo('/verify/student-id');
      else window.location.href = '/verify/student-id';
    });
  }
})();
</script>

</body>
</html>
