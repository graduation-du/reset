<%- include('partials/head') %>

<%- include('partials/navbar') %>
<%- include('partials/background') %>
<%- include('partials/overlays') %>

<main class="relative z-10 flex flex-col items-center justify-center min-h-screen px-10 pt-28 pb-24" data-idle-enabled="true">
  <div class="w-full max-w-3xl screen-transition">

    <%- include('partials/progress', { step: 3 }) %>

    <!-- Student Name Banner -->
    <div id="student-greeting" class="hidden mb-5 glass-panel px-6 py-4 rounded-2xl border border-primary/20 flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-primary text-2xl">person</span>
      </div>
      <div class="text-left">
        <p class="text-on-surface-variant text-sm uppercase tracking-widest font-label" data-i18n="shared.verifyAs">Verifying as</p>
        <p id="student-name-text" class="text-white font-headline font-bold text-xl"></p>
      </div>
    </div>

    <div class="glass-panel p-12 rounded-[2.5rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] border-t border-white/10 relative overflow-hidden">
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-tertiary/20 blur-3xl rounded-full"></div>

      <div class="relative z-10 flex flex-col items-center text-center">
        <div class="w-20 h-20 rounded-2xl bg-tertiary/10 flex items-center justify-center mb-8">
          <span class="material-symbols-outlined filled text-5xl text-tertiary">credit_card</span>
        </div>

        <h2 class="font-headline text-5xl font-bold text-white mb-3" data-i18n="cid.title">Enter Your Civil ID</h2>
        <p class="text-on-surface-variant text-xl mb-10" data-i18n="cid.subtitle">Your Civil ID is your national identity card number</p>

        <!-- Input -->
        <div class="w-full mb-8">
          <div class="relative">
            <span class="material-symbols-outlined input-icon-start text-on-surface-variant text-2xl">badge</span>
            <input
              type="text"
              id="civil-id-input"
              inputmode="numeric"
              pattern="[0-9]*"
              autocomplete="off"
              maxlength="10"
              placeholder="Enter Civil ID Number"
              data-i18n-placeholder="cid.placeholder"
              data-vkb="numeric"
              data-privacy
              class="w-full py-6 rounded-2xl bg-surface-container-highest/50 border border-outline-variant/30 text-white text-2xl font-headline tracking-[0.3em] text-center placeholder:tracking-normal placeholder:text-on-surface-variant/50 focus:outline-none focus:border-tertiary focus:shadow-[0_0_20px_rgba(255,171,243,0.2)] transition-all input-pad-icon"
            />
          </div>
          <p id="civil-id-error" class="hidden mt-3 text-error text-lg text-left flex items-center gap-2">
            <span class="material-symbols-outlined text-xl">error</span>
            <span></span>
          </p>
        </div>

        <!-- Status -->
        <div id="civil-id-status" class="mb-8 flex items-center gap-3 text-lg text-on-surface-variant/60">
          <span class="material-symbols-outlined text-xl">hourglass_empty</span>
          <span data-i18n="cid.status">Awaiting Civil ID</span>
        </div>

        <!-- Buttons -->
        <div class="w-full flex flex-col gap-4">
          <button id="civil-id-submit" class="ripple w-full py-6 rounded-2xl bg-gradient-to-br from-primary to-primary-container font-headline font-bold text-2xl text-on-primary transition-all hover:scale-[1.02] active:scale-95 shadow-[0_0_20px_rgba(2,230,0,0.3)] disabled:opacity-40 disabled:hover:scale-100 disabled:shadow-none flex items-center justify-center gap-4">
            <span class="btn-text" data-i18n="cid.verify">Verify & Continue</span>
            <span class="btn-spinner hidden"><svg class="animate-spin h-7 w-7" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg></span>
            <span class="btn-loading-text hidden">Verifying…</span>
            <span class="material-symbols-outlined btn-arrow text-2xl">arrow_forward</span>
          </button>
          <div class="flex gap-4">
            <a href="/verify/dob" class="ripple flex-1 py-5 rounded-2xl border border-outline-variant/30 glass-panel font-headline font-bold text-xl text-white text-center transition-all hover:scale-[1.02] active:scale-95 flex items-center justify-center gap-3">
              <span class="material-symbols-outlined text-2xl">arrow_back</span> <span data-i18n="onboard.back">Back</span>
            </a>
            <button id="cancel-btn" class="ripple flex-1 py-5 rounded-2xl border border-error-container/30 glass-panel font-headline font-bold text-xl text-error/80 text-center transition-all hover:scale-[1.02] active:scale-95">
              <span data-i18n="sid.cancel">Cancel & Exit</span>
            </button>
          </div>
        </div>

        <p id="attempt-counter" class="hidden mt-5 text-on-surface-variant/60 text-base">
          <span data-i18n="shared.attempts">Attempts remaining:</span> <span id="attempts-left">3</span>
        </p>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>

<script src="/js/idle-timeout.js"></script>
<script src="/js/cancel.js"></script>
<script src="/js/virtual-keyboard.js"></script>
<script src="/js/privacy-shield.js"></script>
<script src="/js/activity-log.js"></script>
<script>
  (function() {
    const sn = sessionStorage.getItem('studentName');
    if (sn) {
      document.getElementById('student-name-text').textContent = sn;
      document.getElementById('student-greeting').classList.remove('hidden');
    }
  })();
</script>
<script>
  (function() {
    const input = document.getElementById('civil-id-input');
    const submitBtn = document.getElementById('civil-id-submit');
    const errorEl = document.getElementById('civil-id-error');
    const statusEl = document.getElementById('civil-id-status');
    const attemptCounter = document.getElementById('attempt-counter');
    const attemptsLeft = document.getElementById('attempts-left');
    const maxAttempts = <%= config.MAX_ATTEMPTS %>;
    let failures = parseInt(sessionStorage.getItem('civilIdFailures') || '0');

    // Numeric only
    input.addEventListener('input', () => {
      input.value = input.value.replace(/\D/g, '');
      hideError();
    });

    function showError(msg) {
      errorEl.classList.remove('hidden');
      errorEl.querySelector('span:last-child').textContent = msg;
      input.classList.add('border-error');
      input.classList.remove('border-outline-variant/30');
    }
    function hideError() {
      errorEl.classList.add('hidden');
      input.classList.remove('border-error');
      input.classList.add('border-outline-variant/30');
    }

    function setLoading(loading) {
      submitBtn.disabled = loading;
      input.disabled = loading;
      submitBtn.querySelector('.btn-text').classList.toggle('hidden', loading);
      submitBtn.querySelector('.btn-arrow').classList.toggle('hidden', loading);
      submitBtn.querySelector('.btn-spinner').classList.toggle('hidden', !loading);
      submitBtn.querySelector('.btn-loading-text').classList.toggle('hidden', !loading);
    }

    function lockSession() {
      input.disabled = true;
      submitBtn.disabled = true;
      showError('Too many failed attempts. Please visit the IT Help Desk for assistance.');
      statusEl.innerHTML = '<span class="material-symbols-outlined text-base text-error">block</span> <span class="text-error">Session locked</span>';
    }

    submitBtn.addEventListener('click', async () => {
      hideError();
      const val = input.value.trim();

      if (!val) {
        showError('Please enter your Civil ID.');
        return;
      }
      if (val.length < 8) {
        showError('Civil ID must be at least 8 digits.');
        return;
      }
      if (val.length > 10) {
        showError('Civil ID must not exceed 10 digits.');
        return;
      }

      setLoading(true);
      statusEl.innerHTML = '<span class="material-symbols-outlined text-base animate-spin">sync</span> Verifying…';

      try {
        const resp = await fetch('/api/verify/civil-id', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ civilId: val })
        });
        const data = await resp.json();

        if (data.success) {
          if (typeof AudioFeedback !== 'undefined') AudioFeedback.play('success');
          statusEl.innerHTML = '<span class="material-symbols-outlined text-base text-primary">check_circle</span> <span class="text-primary">Verified</span>';
          sessionStorage.setItem('civilId', val);
          sessionStorage.removeItem('civilIdFailures');
          if (typeof ActivityLog !== 'undefined') ActivityLog.addEntry('check_circle', 'log.civilIdVerified');
          setTimeout(() => { window.location.href = '/verify/mobile'; }, 500);
        } else {
          if (typeof AudioFeedback !== 'undefined') AudioFeedback.play('error');
          failures++;
          sessionStorage.setItem('civilIdFailures', failures);
          attemptsLeft.textContent = maxAttempts - failures;
          attemptCounter.classList.remove('hidden');
          if (failures >= maxAttempts) {
            lockSession();
          } else {
            showError(data.message);
            statusEl.innerHTML = '<span class="material-symbols-outlined text-base text-error">error</span> <span class="text-error">Verification failed</span>';
          }
          setLoading(false);
        }
      } catch (e) {
        showError('Service temporarily unavailable. Please try again.');
        setLoading(false);
      }
    });

    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') submitBtn.click();
    });

    if (failures > 0) {
      attemptsLeft.textContent = maxAttempts - failures;
      attemptCounter.classList.remove('hidden');
    }
    if (failures >= maxAttempts) lockSession();
  })();
</script>

</body>
</html>
