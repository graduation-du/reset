<%- include('partials/head') %>

<%- include('partials/navbar') %>
<%- include('partials/background') %>
<%- include('partials/overlays') %>

<main class="relative z-10 flex flex-col items-center justify-center min-h-screen px-10 pt-28 pb-24" data-idle-enabled="true">

  <!-- Onboarding Carousel -->
  <div id="onboarding-container" class="w-full max-w-3xl">

    <!-- Slide 1 -->
    <div class="onboarding-slide screen-transition" data-slide="0">
      <div class="glass-panel p-12 rounded-[2.5rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] border-t border-white/10 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-secondary/20 blur-3xl rounded-full"></div>
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-24 h-24 rounded-2xl bg-secondary/10 flex items-center justify-center mb-8">
            <span class="material-symbols-outlined filled text-6xl text-secondary">badge</span>
          </div>
          <h2 class="font-headline text-5xl font-bold text-white mb-4" data-i18n="onboard.s1.title">We'll Verify Your Identity</h2>
          <p class="text-on-surface-variant text-xl leading-relaxed mb-10" data-i18n="onboard.s1.desc" data-i18n-html="true">Have your <span class="text-secondary font-semibold">Student Card</span> and <span class="text-secondary font-semibold">Date of Birth</span> ready. This ensures only you can reset your password.</p>

          <div class="w-full grid grid-cols-2 gap-4 mb-10">
            <div class="glass-panel p-5 rounded-xl border border-white/5 flex items-center gap-4">
              <span class="material-symbols-outlined text-primary text-3xl">badge</span>
              <span class="text-lg text-on-surface" data-i18n="onboard.s1.card">Student Card</span>
            </div>
            <div class="glass-panel p-5 rounded-xl border border-white/5 flex items-center gap-4">
              <span class="material-symbols-outlined text-primary text-3xl">calendar_month</span>
              <span class="text-lg text-on-surface" data-i18n="onboard.s1.dob">Date of Birth</span>
            </div>
          </div>

          <p class="text-on-surface-variant/60 text-lg">
            <span class="material-symbols-outlined text-lg align-middle mr-1">schedule</span>
            <span data-i18n="onboard.s1.time">Takes approximately 3 minutes</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="onboarding-slide hidden" data-slide="1">
      <div class="glass-panel p-12 rounded-[2.5rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] border-t border-white/10 relative overflow-hidden screen-transition">
        <div class="absolute -top-24 -left-24 w-48 h-48 bg-tertiary/20 blur-3xl rounded-full"></div>
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-24 h-24 rounded-2xl bg-tertiary/10 flex items-center justify-center mb-8">
            <span class="material-symbols-outlined filled text-6xl text-tertiary">verified_user</span>
          </div>
          <h2 class="font-headline text-5xl font-bold text-white mb-4" data-i18n="onboard.s2.title">Additional Verification Required</h2>
          <p class="text-on-surface-variant text-xl leading-relaxed mb-10" data-i18n="onboard.s2.desc" data-i18n-html="true">You'll also need your <span class="text-tertiary font-semibold">Civil ID</span> and <span class="text-tertiary font-semibold">registered mobile number</span> to complete the verification process.</p>

          <div class="w-full grid grid-cols-2 gap-4 mb-10">
            <div class="glass-panel p-5 rounded-xl border border-white/5 flex items-center gap-4">
              <span class="material-symbols-outlined text-tertiary text-3xl">credit_card</span>
              <span class="text-lg text-on-surface" data-i18n="onboard.s2.civil">Civil ID</span>
            </div>
            <div class="glass-panel p-5 rounded-xl border border-white/5 flex items-center gap-4">
              <span class="material-symbols-outlined text-tertiary text-3xl">phone_android</span>
              <span class="text-lg text-on-surface" data-i18n="onboard.s2.mobile">Mobile Number</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="onboarding-slide hidden" data-slide="2">
      <div class="glass-panel p-12 rounded-[2.5rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] border-t border-white/10 relative overflow-hidden screen-transition">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/20 blur-3xl rounded-full"></div>
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-24 h-24 rounded-2xl bg-primary/10 flex items-center justify-center mb-8">
            <span class="material-symbols-outlined filled text-6xl text-primary">lock</span>
          </div>
          <h2 class="font-headline text-5xl font-bold text-white mb-4" data-i18n="onboard.s3.title">Your New Password Will Be SMS'd to You</h2>
          <p class="text-on-surface-variant text-xl leading-relaxed mb-10" data-i18n="onboard.s3.desc" data-i18n-html="true">Once verified, a <span class="text-primary font-semibold">new secure password</span> is generated and sent to your mobile instantly.</p>

          <div class="glass-panel p-6 rounded-xl border border-primary/20 w-full mb-6">
            <div class="flex items-center gap-4 justify-center">
              <span class="material-symbols-outlined text-primary text-3xl">sms</span>
              <span class="text-on-surface font-headline font-semibold text-xl" data-i18n="onboard.s3.sms">Password delivered via SMS</span>
            </div>
          </div>
          <p class="text-on-surface-variant/60 text-lg">
            <span class="material-symbols-outlined text-lg align-middle mr-1">security</span>
            <span data-i18n="onboard.s3.security">Your password is never shown on screen</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Navigation Controls -->
    <div class="mt-10 flex items-center justify-between">
      <button id="onboarding-back" class="ripple flex items-center gap-3 px-8 py-5 rounded-2xl border border-outline-variant/30 glass-panel font-headline font-bold text-xl text-white transition-all hover:scale-[1.02] active:scale-95">
        <span class="material-symbols-outlined text-2xl">arrow_back</span>
        <span data-i18n="onboard.back">Back</span>
      </button>

      <!-- Dot Indicators -->
      <div class="flex gap-3">
        <div class="onboarding-dot w-4 h-4 rounded-full bg-primary transition-all duration-300" data-dot="0"></div>
        <div class="onboarding-dot w-4 h-4 rounded-full bg-outline-variant/40 transition-all duration-300" data-dot="1"></div>
        <div class="onboarding-dot w-4 h-4 rounded-full bg-outline-variant/40 transition-all duration-300" data-dot="2"></div>
      </div>

      <button id="onboarding-next" class="ripple flex items-center gap-3 px-8 py-5 rounded-2xl bg-gradient-to-br from-primary to-primary-container font-headline font-bold text-xl text-on-primary transition-all hover:scale-[1.02] active:scale-95 shadow-[0_0_20px_rgba(2,230,0,0.3)]">
        <span id="next-text" data-i18n="onboard.next">Next</span>
        <span class="material-symbols-outlined text-2xl">arrow_forward</span>
      </button>
    </div>

    <!-- Skip Option -->
    <div class="mt-6 text-center">
      <a href="/verify/student-id" class="ripple inline-flex items-center gap-3 px-7 py-4 rounded-full glass-panel border border-outline-variant/20 text-on-surface-variant text-lg font-label font-medium transition-all duration-300 hover:border-primary/40 hover:text-primary hover:shadow-[0_0_15px_rgba(2,230,0,0.15)] active:scale-95">
        <span class="material-symbols-outlined text-xl">skip_next</span>
        <span data-i18n="onboard.skip">Skip Onboarding</span>
      </a>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

<script>
  (function() {
    let currentSlide = 0;
    const slides = document.querySelectorAll('.onboarding-slide');
    const dots = document.querySelectorAll('.onboarding-dot');
    const backBtn = document.getElementById('onboarding-back');
    const nextBtn = document.getElementById('onboarding-next');
    const totalSlides = slides.length;

    function showSlide(index) {
      slides.forEach(s => s.classList.add('hidden'));
      dots.forEach(d => {
        d.classList.remove('bg-primary');
        d.classList.add('bg-outline-variant/40');
      });

      slides[index].classList.remove('hidden');
      slides[index].querySelector('.glass-panel').classList.add('screen-transition');
      dots[index].classList.remove('bg-outline-variant/40');
      dots[index].classList.add('bg-primary');

      // Update button text
      if (index === totalSlides - 1) {
        nextBtn.querySelector('#next-text').setAttribute('data-i18n', 'onboard.getStarted');
        nextBtn.querySelector('#next-text').textContent = typeof I18N !== 'undefined' ? I18N.t('onboard.getStarted') : 'Get Started';
      } else {
        nextBtn.querySelector('#next-text').setAttribute('data-i18n', 'onboard.next');
        nextBtn.querySelector('#next-text').textContent = typeof I18N !== 'undefined' ? I18N.t('onboard.next') : 'Next';
      }
    }

    nextBtn.addEventListener('click', () => {
      if (typeof AudioFeedback !== 'undefined') AudioFeedback.play('navigate');
      if (currentSlide < totalSlides - 1) {
        currentSlide++;
        showSlide(currentSlide);
      } else {
        navigateTo('/verify/student-id');
      }
    });

    backBtn.addEventListener('click', () => {
      if (typeof AudioFeedback !== 'undefined') AudioFeedback.play('navigate');
      if (currentSlide > 0) {
        currentSlide--;
        showSlide(currentSlide);
      } else {
        navigateTo('/');
      }
    });

    showSlide(0);
  })();
</script>
<script src="/js/idle-timeout.js"></script>

</body>
</html>
